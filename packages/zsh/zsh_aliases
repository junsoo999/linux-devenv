#!/bin/zsh

# Net alias
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'
alias chdir='sudo chown junsoo:castlab -R'
alias tt='tmux attach -t'
alias tkill='tmux kill-sessing -t'
alias fmake='make -j$(nproc --all)'

function cd
{
  builtin cd "$@" && pwd;
}

# Bashrc
alias vi='vim -X'
alias vc='vi ~/.zshrc'
alias va='vi ~/.zsh_aliases'
alias sc='source ~/.zshrc'
alias vv='vi ~/.zsh_variables'
alias vimrc='vi ~/.vim/vimrc'

# Monitoring
alias gpu="watch -n 1 nvidia-smi"
alias lpu="watch -n 1 hyperdex-smi"

# Projects
if [ -d $HOME/projects/aida/ ]; then
  export AIDA_HOME=$HOME/projects/aida/
  source $AIDA_HOME/.setup.sh
fi
if [ -d $HOME/projects/bertha/ ]; then
  export BERTHA_HOME=$HOME/projects/bertha/
  source $BERTHA_HOME/.setup.sh
fi